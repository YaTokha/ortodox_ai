APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=dev

# Для русского GPT-2 можно использовать ai-forever/rugpt3small_based_on_gpt2
BASE_MODEL_NAME=ai-forever/rugpt3small_based_on_gpt2
LORA_ADAPTER_PATH=
USE_GPU_IF_AVAILABLE=true
MAX_INPUT_CHARS=12000

CORPUS_PATH=data/processed/corpus.jsonl
TOP_K_RETRIEVAL=4

# Если true, сервис будет работать без загрузки HF модели (fallback-режим)
DISABLE_MODEL=false
